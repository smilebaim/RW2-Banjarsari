
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for common authorization patterns
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Verifies if the requesting user has an administrator role.
     * Uses exists() for efficiency and authorization independence.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Admin and Infrastructure ---

    match /admin_roles/{adminUserId} {
      // Users can see their own role; Admins can see everyone's.
      allow get: if isOwner(adminUserId) || isAdmin();
      allow list: if isAdmin();
      // Allow users to bootstrap their own admin role during initialization
      allow create: if isOwner(adminUserId);
      allow update: if isAdmin() && (request.resource.data.id == resource.data.id);
      allow delete: if isAdmin();
    }

    match /map_settings/{settingId} {
      // Public access to map infrastructure
      allow get, list: if true;
      // Only admins can modify map boundaries, lines, and markers
      allow write: if isAdmin();
    }

    // --- Community Content ---

    match /rw_management_members/{memberId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /announcements_management/{announcementId} {
      allow get, list, create, update, delete: if isAdmin();
    }

    match /announcements_public/{announcementId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /important_contacts/{contactId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    // --- Resident Interaction ---

    match /resident_feedback/{feedbackId} {
      // Anyone signed in (including anonymous) can submit feedback
      allow create: if isSignedIn();
      // Only admins can process or view feedback details
      allow get, list, update, delete: if isAdmin();
    }
  }
}
